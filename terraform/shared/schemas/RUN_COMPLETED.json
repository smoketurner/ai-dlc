{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "RUN.COMPLETED",
  "description": "The run reached its terminal success state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "type",
    "timestamp",
    "run_id",
    "correlation_id",
    "actor_id",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "event_id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["RUN.COMPLETED"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": ["string", "null"], "format": "uuid" },
    "actor_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_slug", "spec_slug", "tasks_completed"],
      "properties": {
        "project_slug": { "type": "string", "minLength": 1, "maxLength": 64 },
        "spec_slug": { "type": "string", "minLength": 1, "maxLength": 128 },
        "tasks_completed": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
