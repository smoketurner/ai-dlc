{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "CHECKS.FAILED",
  "description": "One or more required GitHub Checks for the impl PR's HEAD sha did not succeed. Triggers an implementer revision (counts toward MAX_REVISIONS).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "type",
    "timestamp",
    "run_id",
    "correlation_id",
    "actor_id",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "event_id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["CHECKS.FAILED"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": ["string", "null"], "format": "uuid" },
    "actor_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_slug",
        "pr_url",
        "head_sha",
        "delivery_id",
        "failed_workflow_count",
        "summary"
      ],
      "properties": {
        "project_slug": { "type": "string", "minLength": 1, "maxLength": 64 },
        "pr_url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^https://github\\.com/.+/pull/[0-9]+$"
        },
        "head_sha": { "type": "string", "minLength": 7, "maxLength": 40 },
        "delivery_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "failed_workflow_count": { "type": "integer", "minimum": 1 },
        "summary": { "type": "string", "maxLength": 2048 }
      }
    }
  }
}
