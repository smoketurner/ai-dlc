{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "SPEC.READY",
  "description": "The architect agent produced a spec bundle (requirements, design, tasks) and is awaiting approval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "type",
    "timestamp",
    "run_id",
    "correlation_id",
    "actor_id",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "event_id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["SPEC.READY"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": ["string", "null"], "format": "uuid" },
    "actor_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_slug",
        "spec_slug",
        "spec_s3_prefix",
        "requirements_summary",
        "design_summary",
        "task_count",
        "session_id"
      ],
      "properties": {
        "project_slug": { "type": "string", "minLength": 1, "maxLength": 64 },
        "spec_slug": { "type": "string", "minLength": 1, "maxLength": 128 },
        "spec_s3_prefix": { "type": "string", "minLength": 1 },
        "requirements_summary": { "type": "string", "maxLength": 1024 },
        "design_summary": { "type": "string", "maxLength": 1024 },
        "task_count": { "type": "integer", "minimum": 1 },
        "proposed_adrs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "session_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
