{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "IMPL.ITERATION_REQUESTED",
  "description": "A signal on the impl PR (typically an @aidlc-bot mention) that should trigger an implementer revision. Uncapped; the human is actively steering.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "type",
    "timestamp",
    "run_id",
    "correlation_id",
    "actor_id",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "event_id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["IMPL.ITERATION_REQUESTED"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": ["string", "null"], "format": "uuid" },
    "actor_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_slug",
        "pr_url",
        "delivery_id",
        "source",
        "commenter",
        "feedback_body"
      ],
      "properties": {
        "project_slug": { "type": "string", "minLength": 1, "maxLength": 64 },
        "pr_url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^https://github\\.com/.+/pull/[0-9]+$"
        },
        "delivery_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "source": {
          "type": "string",
          "enum": ["issue_comment_mention", "review_comment_mention", "review_changes_requested"]
        },
        "commenter": { "type": "string", "minLength": 1, "maxLength": 128 },
        "feedback_body": { "type": "string", "minLength": 1, "maxLength": 8192 }
      }
    }
  }
}
