{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "IMPL_PR.OPENED",
  "description": "The implementer opened the single impl PR for this run. Advances the run from implementer_running to impl_pr_open; the state router dispatches the three validators (reviewer, tester, code-critic) next.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "type",
    "timestamp",
    "run_id",
    "correlation_id",
    "actor_id",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "event_id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["IMPL_PR.OPENED"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": ["string", "null"], "format": "uuid" },
    "actor_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_slug", "pr_url", "diff_summary", "session_id"],
      "properties": {
        "project_slug": { "type": "string", "minLength": 1, "maxLength": 64 },
        "pr_url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^https://github\\.com/.+/pull/[0-9]+$"
        },
        "diff_summary": { "type": "string", "maxLength": 4096 },
        "session_id": { "type": "string", "minLength": 1 },
        "token_in": { "type": "integer", "minimum": 0 },
        "token_out": { "type": "integer", "minimum": 0 },
        "cost_usd": { "type": "number", "minimum": 0.0 },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
