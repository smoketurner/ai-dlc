{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "ISSUE.ASK_POSTED",
  "description": "The Triage agent posted a clarifying question on an issue and is awaiting a reply.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "type",
    "timestamp",
    "run_id",
    "correlation_id",
    "actor_id",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "event_id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["ISSUE.ASK_POSTED"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": ["string", "null"], "format": "uuid" },
    "actor_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_slug",
        "target_repo",
        "issue_url",
        "issue_number",
        "comment_url",
        "question_count",
        "session_id"
      ],
      "properties": {
        "project_slug": { "type": "string", "minLength": 1, "maxLength": 64 },
        "target_repo": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^[\\w.-]+/[\\w.-]+$"
        },
        "issue_url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^https://github\\.com/.+$"
        },
        "issue_number": { "type": "integer", "minimum": 1 },
        "comment_url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^https://github\\.com/.+$"
        },
        "question_count": { "type": "integer", "minimum": 1, "maximum": 8 },
        "session_id": { "type": "string" }
      }
    }
  }
}
