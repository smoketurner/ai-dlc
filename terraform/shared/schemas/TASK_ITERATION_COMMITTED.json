{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "TASK.ITERATION_COMMITTED",
  "description": "The implementer pushed a fix commit during iteration; the reactor dispatches Reviewer + Tester next.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "type",
    "timestamp",
    "run_id",
    "correlation_id",
    "actor_id",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "event_id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["TASK.ITERATION_COMMITTED"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": ["string", "null"], "format": "uuid" },
    "actor_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_slug",
        "spec_slug",
        "task_id",
        "pr_url",
        "iteration_count",
        "head_sha",
        "diff_summary",
        "session_id"
      ],
      "properties": {
        "project_slug": { "type": "string", "minLength": 1, "maxLength": 64 },
        "spec_slug": { "type": "string", "minLength": 1, "maxLength": 128 },
        "task_id": { "type": "string", "minLength": 1, "maxLength": 32 },
        "pr_url": { "type": "string", "format": "uri" },
        "iteration_count": { "type": "integer", "minimum": 1, "maximum": 16 },
        "head_sha": { "type": "string", "minLength": 7, "maxLength": 40 },
        "inline_replies_count": { "type": "integer", "minimum": 0 },
        "diff_summary": { "type": "string", "maxLength": 4096 },
        "session_id": { "type": "string", "minLength": 1 },
        "token_in": { "type": "integer", "minimum": 0 },
        "token_out": { "type": "integer", "minimum": 0 },
        "cost_usd": { "type": "number", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
