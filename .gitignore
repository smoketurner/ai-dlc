# Tailwind CLI binary cache (build-tailwind.sh downloads the pinned standalone
# release on demand). The generated tailwind.css IS committed — `terraform plan`
# regenerates it via build-tailwind.sh, but a committed copy keeps local
# `uvicorn` dev working without the binary.
services/dashboard/.bin/

# Python / uv
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
.env.*
!.env.example
*.egg-info/
*.egg
build/
dist/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ty_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
.hypothesis/

# Lambda packaging
lambdas/*/dist/
lambdas/*/build/

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
# Personal overrides only — gitignore terraform.tfvars + any *.local.tfvars,
# but allow *.auto.tfvars (committed team-shared config) and the .example.
*.tfvars
!*.auto.tfvars
!*.tfvars.example
backend.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Docker
.dockerignore.local

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Claude Code local settings
.claude/settings.local.json

# Local-only workspace (private plans, scratch notes)
.local/
/terraform/envs/dev/builds
terraform/envs/dev/tfplan
terraform/envs/dev/secrets.auto.tfvars
terraform/envs/dev/*.private-key.pem
